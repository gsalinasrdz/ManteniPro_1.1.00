# ────────────────────────────────────────────────────────────
#  ManteniPro — Variables de entorno
#  Copia este archivo a .env.local y completa los valores
# ────────────────────────────────────────────────────────────

# Database — Postgres (Supabase / Neon / local Docker)
DATABASE_URL="postgresql://user:password@localhost:5432/mantenipro?schema=public"

# Auth.js
AUTH_SECRET="<genera con: openssl rand -base64 32>"
AUTH_URL="http://localhost:3000"

# Auth providers (opcional, según los que uses)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# UploadThing (fotos de OTs, evidencias)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Telemetría (opcional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Entorno
NODE_ENV="development"
